{
  "name": "antigravity-auto-retry",
  "displayName": "Auto Retry for Antigravity",
  "description": "Tự động bấm nút Retry khi Antigravity IDE gặp lỗi API/rate limit. v4.1 Safe-Only — chỉ quét Toast/Dialog/Iframe, rate limit 10/min.",
  "version": "4.1.0",
  "publisher": "skyline",
  "repository": {
    "type": "git",
    "url": "https://github.com/thanhndp/antigravity-auto-retry"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autoRetry.inject",
        "title": "Auto Retry: Inject Script"
      },
      {
        "command": "autoRetry.copyScript",
        "title": "Auto Retry: Copy Script to Clipboard"
      }
    ],
    "keybindings": [
      {
        "command": "autoRetry.inject",
        "key": "ctrl+alt+r",
        "when": "true"
      }
    ]
  }
}
